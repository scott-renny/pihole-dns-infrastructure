# Copy this file to .env and fill in your own values.
# .env is in .gitignore — never commit your real values.

# Timezone for log timestamps
TZ=America/New_York

# Pi-hole web admin password — set a strong password, do not reuse it elsewhere
WEBPASSWORD=ChangeMe123!

# Host port for the Pi-hole web UI.
# Default is 8081 because port 80 is occupied by an existing web service in this lab
# (see docs/PHASE1-troubleshooting.md, Problem 2). Change if your environment is different.
PIHOLE_WEBPORT=8081

# UID/GID Pi-hole runs as inside the container.
# Must match your host user's UID/GID or you will hit the volume permission
# issue documented in docs/PHASE1-troubleshooting.md, Problem 3.
# Run `id -u` and `id -g` on your Ubuntu host to find your own values.
PIHOLE_UID=1000
PIHOLE_GID=1000
